{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "postinstall": "patch-package",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "jest": {
    "preset": "jest-expo",
    "maxWorkers": 1,
    "setupFiles": [
      "./jest.setup.js"
    ],
    "testMatch": [
      "**/src/__tests__/**/*.test.{ts,tsx}"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|lucide-react-native))"
    ],
    "moduleNameMapper": {
      "\\.(jpg|jpeg|png|gif|webp|svg)$": "<rootDir>/src/__mocks__/fileMock.js",
      "^expo/src/winter/(.*)$": "<rootDir>/src/__mocks__/expo-winter.js",
      "^react-redux$": "<rootDir>/node_modules/react-redux/dist/cjs/react-redux.development.cjs",
      "^immer$": "<rootDir>/node_modules/immer/dist/cjs/immer.cjs.development.js"
    },
    "collectCoverageFrom": [
      "src/screens/Auth.tsx",
      "src/screens/CardCreate.tsx",
      "src/screens/Index.tsx",
      "src/hooks/useAuth.tsx",
      "src/hooks/useBusinessCards.ts",
      "src/store/api/authApi.ts",
      "src/store/api/businessCardsApi.ts",
      "src/store/authSlice.ts"
    ]
  },
  "dependencies": {
    "@expo-google-fonts/plus-jakarta-sans": "^0.4.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/slider": "5.0.1",
    "@react-navigation/native": "^7.2.0",
    "@react-navigation/native-stack": "^7.14.7",
    "@reduxjs/toolkit": "^2.11.2",
    "@supabase/supabase-js": "^2.100.0",
    "@tanstack/react-query": "^5.95.2",
    "babel-preset-expo": "~54.0.10",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "expo": "~54.0.0",
    "expo-application": "~7.0.8",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-contacts": "~15.0.11",
    "expo-dev-client": "~6.0.20",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-location": "~19.0.8",
    "expo-notifications": "^0.32.16",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "lucide-react-native": "^1.6.0",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-calendars": "^1.1314.0",
    "react-native-css-interop": "^0.2.3",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-razorpay": "^2.3.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-share": "^12.2.6",
    "react-native-svg": "15.12.1",
    "react-native-view-shot": "4.0.3",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "^0.8.1",
    "react-redux": "^9.2.0",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@babel/plugin-proposal-export-namespace-from": "^7.18.9",
    "@babel/plugin-transform-template-literals": "^7.25.9",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.10",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.0",
    "lightningcss-wasm": "^1.32.0",
    "patch-package": "^8.0.1",
    "react-test-renderer": "^19.1.0",
    "sharp": "^0.34.5",
    "typescript": "~5.9.2"
  },
  "private": true
}
